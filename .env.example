# Shared application settings
APP_ENV=development
APP_NAME=Orgx
API_HOST=127.0.0.1
API_PORT=8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project settings
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_DB_HOST=db.your-project-id.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password
DATABASE_URL=postgresql+psycopg://postgres:your-supabase-db-password@db.your-project-id.supabase.co:5432/postgres

# Optional Supabase client settings for Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Auth and security
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Wallet and blockchain
EVM_CHAIN_ID=80002
EVM_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-key
TREASURY_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=replace-with-a-secure-private-key
PAYOUT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
PAYOUT_TOKEN_SYMBOL=USDC

# Attendance and verification
FACE_PROVIDER=mock
FACE_PROVIDER_API_KEY=
FACE_PROVIDER_BASE_URL=
